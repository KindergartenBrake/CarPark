@inherits LayoutComponentBase

<RadzenComponents />

<style>
    .brutal-page {
        min-height: 100vh;
        background: linear-gradient(135deg, #0a1928 0%, #0d2b3e 50%, #0a1928 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }
    
    .brutal-card {
        max-width: 1000px;
        width: 100%;
        background: linear-gradient(135deg, #1a2a3a 0%, #16212e 100%);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 8px 16px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.05);
        border: 1px solid #2a4a6e;
    }
    
    .brand-side {
        background: linear-gradient(135deg, #0a121a 0%, #0d1620 100%);
        padding: 48px;
        height: 100%;
        border-right: 1px solid #2a4a6e;
    }
    
    .form-side {
        background: linear-gradient(135deg, #141f2b 0%, #111a24 100%);
        padding: 48px;
        height: 100%;
    }
    
    .logo {
        width: 64px;
        margin-bottom: 32px;
        filter: brightness(0) invert(1);
    }
    
    h2 {
        color: #e0e8f0;
        font-size: 28px;
        font-weight: 500;
        margin-bottom: 12px;
        letter-spacing: -0.3px;
    }
    
    .subtitle {
        color: #8aa0b5;
        font-size: 14px;
        line-height: 1.5;
    }
    
    hr {
        border: none;
        height: 1px;
        background: #2a4a6e;
        margin: 32px 0 20px;
    }
    
    .version {
        font-size: 12px;
        color: #5a7a9a;
    }
    
    .brutal-input {
        background: #0f1a24 !important;
        border: 1px solid #2a4a6e !important;
        color: #e0e8f0 !important;
        border-radius: 6px !important;
        padding: 10px 12px !important;
    }
    
    .brutal-input:focus {
        border-color: #3a8bc5 !important;
        box-shadow: 0 0 0 2px rgba(58,139,197,0.2) !important;
        background: #121f2c !important;
    }
    
    .brutal-input::placeholder {
        color: #5a7a9a !important;
    }
    
    .brutal-label {
        color: #8aa0b5 !important;
        font-weight: 500;
        margin-bottom: 8px;
        display: block;
    }
    
    .brutal-btn {
        background: linear-gradient(135deg, #1e5799 0%, #2b7abf 100%);
        border: 1px solid #3a8bc5;
        color: white;
        font-weight: bold;
        padding: 10px 24px;
        border-radius: 6px;
        width: 100%;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    
    .brutal-btn:hover {
        background: linear-gradient(135deg, #2b6aae 0%, #3a8bc5 100%);
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(30,87,153,0.4);
    }
    
    @@media (max-width: 768px) {
        .brand-side, .form-side {
            padding: 32px;
        }
        
        .logo {
            width: 48px;
            margin-bottom: 24px;
        }
        
        h2 {
            font-size: 24px;
        }
    }
</style>

<div class="brutal-page">
    <div class="brutal-card">
        <div style="display: flex; flex-wrap: wrap;">
        
            <div style="flex: 1; min-width: 250px;" class="brand-side">
                <img src="images/logo-login.png" alt="Logo" class="logo" />
                <h2>CarPark</h2>
                <div class="subtitle">Управление автопарком</div>
                <hr />
                <div class="version">v1.0.0</div>
            </div>
            
            <div style="flex: 1; min-width: 280px;" class="form-side">
                @Body
            </div>
            
        </div>
    </div>
</div>