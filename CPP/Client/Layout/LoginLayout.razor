@inherits LayoutComponentBase

<RadzenComponents />

<style>
    .login-page {
        min-height: 100vh;
        background: linear-gradient(135deg, #071120 0%, #0b1f3d 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
    }
    
    .login-card {
        max-width: 1100px;
        width: 100%;
        background: #0c1c33;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
        border: 1px solid #1f4781;
    }
    
    .brand-side {
        background: linear-gradient(145deg, #0d1c34 0%, #0a1628 100%);
        padding: 48px;
        height: 100%;
        border-right: 1px solid #1f4781;
    }
    
    .form-side {
        background: #0c1c33;
        padding: 48px;
        height: 100%;
    }
    
    .logo {
        width: 70px;
        height: 70px;
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 32px;
        font-size: 32px;
        font-weight: bold;
        color: white;
    }
    
    h2 {
        color: #edf4ff;
        font-size: 28px;
        font-weight: 800;
        margin-bottom: 12px;
        letter-spacing: 1px;
    }
    
    .subtitle {
        color: #8aa8cc;
        font-size: 14px;
        line-height: 1.5;
    }
    
    .divider {
        border: none;
        height: 1px;
        background: #1f4781;
        margin: 32px 0 20px;
    }
    
    .version {
        font-size: 12px;
        color: #5f82b5;
    }
    
    /* Стили для Radzen компонентов */
    .login-input {
        background: #08111f !important;
        border: 1px solid #1f4781 !important;
        color: #edf4ff !important;
        border-radius: 10px !important;
        padding: 12px 16px !important;
        font-size: 14px !important;
        width: 100% !important;
    }
    
    .login-input:focus {
        border-color: #3b82f6 !important;
        box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.2) !important;
        background: #0d1c34 !important;
        outline: none;
    }
    
    .login-input::placeholder {
        color: #5f82b5 !important;
    }
    
    .login-label {
        color: #8aa8cc !important;
        font-weight: 600;
        margin-bottom: 8px;
        display: block;
        font-size: 13px;
        letter-spacing: 0.5px;
    }
    
    .login-btn {
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        border: none;
        color: white;
        font-weight: 800;
        padding: 12px 24px;
        border-radius: 10px;
        width: 100%;
        cursor: pointer;
        transition: all 0.2s ease;
        font-size: 14px;
        letter-spacing: 1px;
    }
    
    .login-btn:hover {
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(37, 99, 235, 0.3);
    }
    
    .error-alert {
        background: rgba(220, 38, 38, 0.15);
        border: 1px solid #dc2626;
        border-radius: 10px;
        padding: 12px 16px;
        margin-bottom: 24px;
        color: #fca5a5;
        font-size: 14px;
    }
    
    .info-text {
        text-align: center;
        margin-top: 24px;
        color: #5f82b5;
        font-size: 12px;
    }
    
    .info-text a {
        color: #3b82f6;
        text-decoration: none;
    }
    
    .info-text a:hover {
        text-decoration: underline;
    }
    
    @@media (max-width: 768px) {
        .brand-side, .form-side {
            padding: 32px;
        }
        
        .logo {
            width: 50px;
            height: 50px;
            font-size: 24px;
            margin-bottom: 24px;
        }
        
        h2 {
            font-size: 24px;
        }
    }
</style>

<div class="login-page">
    <div class="login-card">
        <div style="display: flex; flex-wrap: wrap;">
            <div style="flex: 1; min-width: 280px;" class="brand-side">
                <div class="logo">CP</div>
                <h2>CARPARK</h2>
                <div class="subtitle">Система управления автопарком</div>
                <div class="divider"></div>
                <div class="version">v1.0.0</div>
            </div>
            
            <div style="flex: 1; min-width: 320px;" class="form-side">
                @Body
            </div>
        </div>
    </div>
</div>