@inherits LayoutComponentBase

<RadzenComponents />

<style>
    /* Чистый светлый фон */
    .login-page {
        min-height: 100vh;
        background: #f0f2f5;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }
    
    /* Белая карточка */
    .login-card {
        max-width: 1000px;
        width: 100%;
        background: white;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06), 0 4px 16px rgba(0,0,0,0.04);
    }
    
    /* Левая панель — тёмная */
    .brand-side {
        background: #1a1a1a;
        padding: 48px;
        height: 100%;
    }
    
    /* Правая панель — белая */
    .form-side {
        background: white;
        padding: 48px;
        height: 100%;
    }
    
    /* Логотип */
    .logo {
        width: 64px;
        margin-bottom: 32px;
        filter: brightness(0) invert(1);
    }
    
    /* Заголовок */
    h2 {
        color: white;
        font-size: 28px;
        font-weight: 500;
        margin-bottom: 12px;
        letter-spacing: -0.3px;
    }
    
    .subtitle {
        color: rgba(255,255,255,0.6);
        font-size: 14px;
        line-height: 1.5;
    }
    
    /* Разделитель */
    hr {
        border: none;
        height: 1px;
        background: rgba(255,255,255,0.1);
        margin: 32px 0 20px;
    }
    
    /* Версия */
    .version {
        font-size: 12px;
        color: rgba(255,255,255,0.3);
    }
    
    /* Мобильная адаптация */
    @@media (max-width: 768px) {
        .brand-side, .form-side {
            padding: 32px;
        }
        
        .logo {
            width: 48px;
            margin-bottom: 24px;
        }
        
        h2 {
            font-size: 24px;
        }
    }
</style>

<div class="login-page">
    <div class="login-card">
        <div style="display: flex; flex-wrap: wrap;">
            
            <!-- Левая часть -->
            <div style="flex: 1; min-width: 250px;" class="brand-side">
                <img src="images/logo-login.png" alt="Logo" class="logo" />
                <h2>CarPark</h2>
                <div class="subtitle">Управление автопарком</div>
                <hr />
                <div class="version">v1.0.0</div>
            </div>
            
            <!-- Правая часть с формой -->
            <div style="flex: 1; min-width: 280px;" class="form-side">
                @Body
            </div>
            
        </div>
    </div>
</div>