@page "/employee/trip-requests"
@using Microsoft.AspNetCore.Authorization
@using System.ComponentModel.DataAnnotations
@attribute [Authorize(Roles = "Employee")]

<PageTitle>Employee - Мои заявки</PageTitle>

<div style="min-height: 100vh; background: linear-gradient(135deg, #07111f 0%, #0b1f3d 50%, #102a54 100%); padding: 20px;">
    <div style="max-width: 1600px; margin: 0 auto;">

        <!-- Заголовок -->
        <div style="margin-bottom: 30px;">
            <div style="color: #dfefff; font-size: 30px; font-weight: 800; letter-spacing: 1px;">
                МОИ ЗАЯВКИ
            </div>
            <div style="color: #7fa6d9; font-size: 14px; margin-top: 8px;">
                Управление поездками, создание новых заявок и отслеживание статусов
            </div>
        </div>

        <!-- Панель управления -->
        <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px; margin-bottom: 25px;">
            
            <!-- Фильтры -->
            <div style="display: flex; gap: 8px; flex-wrap: wrap; border-bottom: 2px solid #2e5ea7; padding-bottom: 0;">
                @foreach (var status in statuses)
                {
                    var currentStatus = status;
                    <button @onclick="() => SelectStatus(currentStatus)"
                            style="background: @(selectedStatus == currentStatus ? "#2f6edb" : "transparent");
                                   color: @(selectedStatus == currentStatus ? "white" : "#8fb5e8");
                                   border: none;
                                   padding: 12px 22px;
                                   border-radius: 8px 8px 0 0;
                                   cursor: pointer;
                                   font-weight: 700;
                                   transition: all 0.3s ease;">
                        @(currentStatus == "Pending" ? "Ожидают" :
                           currentStatus == "Approved" ? "Одобрены" :
                           currentStatus == "Completed" ? "Завершены" :
                           currentStatus == "Rejected" ? "Отклонены" : "Все")
                    </button>
                }
            </div>

            <!-- Кнопка создания -->
            <button @onclick="OpenCreateModal"
                    style="background: linear-gradient(135deg, #2f6edb, #1c4fa3);
                           color: white;
                           border: none;
                           padding: 14px 24px;
                           border-radius: 10px;
                           font-weight: 700;
                           cursor: pointer;
                           box-shadow: 0 4px 16px rgba(47,110,219,0.4);">
                + СОЗДАТЬ ЗАЯВКУ
            </button>
        </div>

        <!-- Таблица -->
        <div style="background: rgba(10, 25, 50, 0.95);
                   border: 1px solid #2e5ea7;
                   border-radius: 14px;
                   overflow: hidden;
                   box-shadow: 0 8px 32px rgba(0,0,0,0.35);">

            <table style="width: 100%; border-collapse: collapse;">
                <thead style="background: linear-gradient(135deg, #163a70, #0f2a52);">
                    <tr>
                        <th style="padding: 18px; color: #dfefff; text-align: left;">ID</th>
                        <th style="padding: 18px; color: #dfefff; text-align: left;">Дата создания</th>
                        <th style="padding: 18px; color: #dfefff; text-align: left;">Дата поездки</th>
                        <th style="padding: 18px; color: #dfefff; text-align: left;">Тип авто</th>
                        <th style="padding: 18px; color: #dfefff; text-align: left;">Статус</th>
                        <th style="padding: 18px; color: #dfefff; text-align: center;">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var req in filteredRequests)
                    {
                        <tr style="border-bottom: 1px solid rgba(46,94,167,0.25);
                                   transition: all 0.3s ease;">
                            <td style="padding: 18px; color: #e8f2ff; font-weight: 700;">
                                #@req.RequestId
                            </td>
                            <td style="padding: 18px; color: #9bbbe8;">
                                @req.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                            </td>
                            <td style="padding: 18px; color: #9bbbe8;">
                                @req.TripDate.ToString("dd.MM.yyyy HH:mm")
                            </td>
                            <td style="padding: 18px; color: #dfefff;">
                                @req.VehicleType
                            </td>
                            <td style="padding: 18px;">
                                <span style="padding: 6px 14px;
                                            border-radius: 20px;
                                            font-size: 12px;
                                            font-weight: 700;
                                            background: @GetStatusBackground(req.Status);
                                            color: @GetStatusColor(req.Status);">
                                    @(req.Status == "Pending" ? "Ожидает" :
                                       req.Status == "Approved" ? "Одобрена" :
                                       req.Status == "Completed" ? "Завершена" : "Отклонена")
                                </span>
                            </td>
                            <td style="padding: 18px; text-align: center;">
                                <button @onclick="() => OpenDetails(req)"
                                        style="background: transparent;
                                               border: 1px solid #2f6edb;
                                               color: #8fb5e8;
                                               padding: 8px 14px;
                                               border-radius: 8px;
                                               cursor: pointer;">
                                    Подробнее
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!filteredRequests.Any())
            {
                <div style="padding: 60px; text-align: center;">
                    <div style="font-size: 64px;">📄</div>
                    <div style="color: #dfefff; font-size: 20px; font-weight: 700;">
                        Заявки отсутствуют
                    </div>
                    <div style="color: #7fa6d9; margin-top: 8px;">
                        Создайте новую заявку для поездки
                    </div>
                </div>
            }
        </div>

    </div>
</div>

<!-- Модальное окно создания -->
@if (showCreateModal)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.75); display: flex; justify-content: center; align-items: center; z-index: 999;">
        <div style="background: linear-gradient(135deg, #0b1f3d, #07111f); border: 1px solid #2e5ea7; border-radius: 14px; padding: 30px; width: 100%; max-width: 650px; color: white;">
            <h2>Создание заявки</h2>

            <EditForm Model="newRequest" OnValidSubmit="SubmitRequest">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div style="margin-bottom: 16px;">
                    <label>Тип автомобиля</label>
                    <InputSelect @bind-Value="newRequest.VehicleType" style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #2e5ea7; background: #10284d; color: white;">
                        <option value="">Выберите тип</option>
                        @foreach (var type in vehicleTypes)
                        {
                            <option value="@type">@type</option>
                        }
                    </InputSelect>
                </div>

                <div style="margin-bottom: 16px;">
                    <label>Дата поездки</label>
                    <InputDate @bind-Value="newRequest.TripDate" style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #2e5ea7; background: #10284d; color: white;" />
                </div>

                <div style="margin-bottom: 16px;">
                    <label>Время начала</label>
                    <InputDate @bind-Value="newRequest.StartTime" Type="InputDateType.DateTimeLocal" style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #2e5ea7; background: #10284d; color: white;" />
                </div>

                <div style="margin-bottom: 16px;">
                    <label>Время окончания</label>
                    <InputDate @bind-Value="newRequest.EndTime" Type="InputDateType.DateTimeLocal" style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #2e5ea7; background: #10284d; color: white;" />
                </div>

                <div style="margin-bottom: 16px;">
                    <label>Описание</label>
                    <InputTextArea @bind-Value="newRequest.Description" style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #2e5ea7; background: #10284d; color: white;" />
                </div>

                <div style="display:flex; gap:12px; margin-top:20px;">
                    <button type="submit" style="background: #2f6edb; color: white; border: none; padding: 12px 18px; border-radius: 8px; cursor: pointer;">Отправить</button>
                    <button type="button" @onclick="CloseCreateModal" style="background: #243b5e; color: white; border: none; padding: 12px 18px; border-radius: 8px; cursor: pointer;">Отмена</button>
                </div>
            </EditForm>
        </div>
    </div>
}

<!-- Модальное окно деталей -->
@if (selectedRequest is not null)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.75); display: flex; justify-content: center; align-items: center; z-index: 999;">
        <div style="background: linear-gradient(135deg, #0b1f3d, #07111f); border: 1px solid #2e5ea7; border-radius: 14px; padding: 30px; width: 100%; max-width: 650px; color: white;">
            <h2>Детали заявки #@selectedRequest.RequestId</h2>

            <div style="display: grid; gap: 12px; margin-top: 20px;">
                <div><strong>Тип авто:</strong> @selectedRequest.VehicleType</div>
                <div><strong>Дата поездки:</strong> @selectedRequest.TripDate.ToString("dd.MM.yyyy")</div>
                <div><strong>Начало:</strong> @selectedRequest.StartTime?.ToString("HH:mm")</div>
                <div><strong>Окончание:</strong> @selectedRequest.EndTime?.ToString("HH:mm")</div>
                <div><strong>Описание:</strong> @selectedRequest.Description</div>
                <div>
                    <strong>Статус:</strong>
                    <span style="padding: 4px 12px; border-radius: 20px; font-weight: 700;
                                 background: @GetStatusBackground(selectedRequest.Status);
                                 color: @GetStatusColor(selectedRequest.Status);">
                        @(selectedRequest.Status == "Pending" ? "Ожидает" :
                           selectedRequest.Status == "Approved" ? "Одобрена" :
                           selectedRequest.Status == "Completed" ? "Завершена" : "Отклонена")
                    </span>
                </div>
                @if (!string.IsNullOrEmpty(selectedRequest.RejectionReason))
                {
                    <div><strong>Причина отказа:</strong> @selectedRequest.RejectionReason</div>
                }
            </div>

            @if (selectedRequest.Status == "Approved")
            {
                <div style="margin-top:20px; padding:16px; background: rgba(47,110,219,0.1); border-left: 4px solid #2f6edb; border-radius: 8px;">
                    <div><strong>Автомобиль:</strong> @selectedRequest.VehicleBrand @selectedRequest.VehicleModel</div>
                    <div><strong>Госномер:</strong> @selectedRequest.LicensePlate</div>
                    <div><strong>Водитель:</strong> @selectedRequest.DriverName</div>
                    <div><strong>Телефон:</strong> @selectedRequest.DriverPhone</div>
                </div>
            }

            <button @onclick="CloseDetails" style="background: #243b5e; color: white; border: none; padding: 12px 18px; border-radius: 8px; cursor: pointer; margin-top: 20px;">Закрыть</button>
        </div>
    </div>
}

<style>
    tr:hover {
        background: rgba(47,110,219,0.08);
    }
</style>

@code {
    private string GetCarIcon(string type) => type switch
    {
        "Седан" => "🚗",
        "Универсал" => "🚙",    
        "Микроавтобус" => "🚐",
        "Грузовой" => "🚛",
        _ => "🚗"
    };
}