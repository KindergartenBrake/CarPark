@page "/employee/trip-requests"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@attribute [Authorize(Roles = "Employee")]

<PageTitle>Employee - Мои заявки</PageTitle>

<div style="min-height: 100vh; background: linear-gradient(135deg, #07111f 0%, #0b1f3d 50%, #102a54 100%); padding: 20px;">
    <div style="max-width: 1600px; margin: 0 auto;">

        <div style="margin-bottom: 30px;">
            <div style="color: #dfefff; font-size: 30px; font-weight: 800; letter-spacing: 1px;">
                МОИ ЗАЯВКИ
            </div>
            <div style="color: #7fa6d9; font-size: 14px; margin-top: 8px;">
                Управление поездками, создание новых заявок и отслеживание статусов
            </div>
        </div>

        <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px; margin-bottom: 25px;">
            
            <div style="display: flex; gap: 8px; flex-wrap: wrap; border-bottom: 2px solid #2e5ea7; padding-bottom: 0;">
                @foreach (var status in statuses)
                {
                    var currentStatus = status;
                    <button @onclick="() => SelectStatus(currentStatus)"
                            style="background: @(selectedStatus == currentStatus ? "#2f6edb" : "transparent");
                                   color: @(selectedStatus == currentStatus ? "white" : "#8fb5e8");
                                   border: none;
                                   padding: 12px 22px;
                                   border-radius: 8px 8px 0 0;
                                   cursor: pointer;
                                   font-weight: 700;
                                   transition: all 0.3s ease;">
                        @(currentStatus == "Pending" ? "Ожидают" :
                          currentStatus == "Approved" ? "Одобрены" :
                          currentStatus == "Completed" ? "Завершены" :
                          currentStatus == "Rejected" ? "Отклонены" : "Все")
                    </button>
                }
            </div>

            <button @onclick="OpenCreateModal"
                    style="background: linear-gradient(135deg, #2f6edb, #1c4fa3);
                           color: white;
                           border: none;
                           padding: 14px 24px;
                           border-radius: 10px;
                           font-weight: 700;
                           cursor: pointer;
                           box-shadow: 0 4px 16px rgba(47,110,219,0.4);">
                + СОЗДАТЬ ЗАЯВКУ
            </button>
        </div>

        <div style="background: rgba(10, 25, 50, 0.95);
                   border: 1px solid #2e5ea7;
                   border-radius: 14px;
                   overflow: hidden;
                   box-shadow: 0 8px 32px rgba(0,0,0,0.35);">

            <table style="width: 100%; border-collapse: collapse;">
                <thead style="background: linear-gradient(135deg, #163a70, #0f2a52);">
                    <tr>
                        <th style="padding: 18px; color: #dfefff; text-align: left;">ID</th>
                        <th style="padding: 18px; color: #dfefff; text-align: left;">Дата создания</th>
                        <th style="padding: 18px; color: #dfefff; text-align: left;">Дата поездки</th>
                        <th style="padding: 18px; color: #dfefff; text-align: left;">Тип авто</th>
                        <th style="padding: 18px; color: #dfefff; text-align: left;">Время начала</th>
                        <th style="padding: 18px; color: #dfefff; text-align: left;">Время окончания</th>
                        <th style="padding: 18px; color: #dfefff; text-align: left;">Статус</th>
                        <th style="padding: 18px; color: #dfefff; text-align: center;">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var req in filteredRequests)
                    {
                        <tr style="border-bottom: 1px solid rgba(46,94,167,0.25); transition: all 0.3s ease;">
                            <td style="padding: 18px; color: #e8f2ff; font-weight: 700;">#@req.RequestId</td>
                            <td style="padding: 18px; color: #9bbbe8;">@req.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td style="padding: 18px; color: #9bbbe8;">@req.TripDate.ToString("dd.MM.yyyy")</td>
                            <td style="padding: 18px; color: #dfefff;">@req.VehicleType</td>
                            <td style="padding: 18px; color: #9bbbe8;">@(req.StartTime.HasValue ? req.StartTime.Value.ToString(@"hh\:mm") : "-")</td>
                            <td style="padding: 18px; color: #9bbbe8;">@(req.EndTime.HasValue ? req.EndTime.Value.ToString(@"hh\:mm") : "-")</td>
                            <td style="padding: 18px;">
                                <span style="padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 700;
                                             background: @GetStatusBackground(req.Status);
                                             color: @GetStatusColor(req.Status);">
                                    @(req.Status == "Pending" ? "Ожидает" :
                                      req.Status == "Approved" ? "Одобрена" :
                                      req.Status == "Completed" ? "Завершена" : "Отклонена")
                                </span>
                            </td>
                            <td style="padding: 18px; text-align: center;">
                                <button @onclick="() => OpenDetails(req)"
                                        style="background: transparent; border: 1px solid #2f6edb; color: #8fb5e8; padding: 8px 14px; border-radius: 8px; cursor: pointer;">
                                    Подробнее
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!filteredRequests.Any())
            {
                <div style="padding: 60px; text-align: center;">
                    <div style="font-size: 64px;"></div>
                    <div style="color: #dfefff; font-size: 20px; font-weight: 700;">Заявки отсутствуют</div>
                    <div style="color: #7fa6d9; margin-top: 8px;">Создайте новую заявку для поездки</div>
                </div>
            }
        </div>

    </div>
</div>

@if (showCreateModal)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.75); display: flex; justify-content: center; align-items: center; z-index: 999;">
        <div style="background: linear-gradient(135deg, #0b1f3d, #07111f); border: 1px solid #2e5ea7; border-radius: 14px; padding: 30px; width: 100%; max-width: 650px; color: white;">
            <h2 style="margin-top: 0;">Создание заявки</h2>

            <div style="margin-bottom: 16px;">
                <label style="display: block; margin-bottom: 6px; color: #8aa8cc;">Тип автомобиля</label>
                <select @bind="newRequest.VehicleType" style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #2e5ea7; background: #10284d; color: white;">
                    <option value="">Выберите тип</option>
                    @foreach (var type in vehicleTypes)
                    {
                        <option value="@type">@type</option>
                    }
                </select>
            </div>

            <div style="margin-bottom: 16px;">
                <label style="display: block; margin-bottom: 6px; color: #8aa8cc;">Дата поездки</label>
                <input type="date" @bind="newRequest.TripDate" @bind:format="yyyy-MM-dd"
                       style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #2e5ea7; background: #10284d; color: white;" />
            </div>

            <div style="margin-bottom: 16px;">
                <label style="display: block; margin-bottom: 6px; color: #8aa8cc;">Время начала</label>
                <input type="time" value="@startTimeString" @onchange="(ChangeEventArgs e) => startTimeString = e.Value?.ToString()"
                    style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #2e5ea7; background: #10284d; color: white;" />
            </div>

            <div style="margin-bottom: 16px;">
                <label style="display: block; margin-bottom: 6px; color: #8aa8cc;">Время окончания</label>
                <input type="time" value="@endTimeString" @onchange="(ChangeEventArgs e) => endTimeString = e.Value?.ToString()"
                    style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #2e5ea7; background: #10284d; color: white;" />
            </div>
            <div style="margin-bottom: 16px;">
                <label style="display: block; margin-bottom: 6px; color: #8aa8cc;">Описание</label>
                <textarea @bind="newRequest.Description" rows="3"
                          style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #2e5ea7; background: #10284d; color: white;"></textarea>
            </div>

            <div style="display: flex; gap: 12px; margin-top: 20px; justify-content: flex-end;">
                <button @onclick="CloseCreateModal" style="background: #1e293b; border: none; color: #8aa8cc; padding: 10px 20px; border-radius: 8px; cursor: pointer;">Отмена</button>
                <button @onclick="SubmitRequest" style="background: #2f6edb; border: none; color: white; padding: 10px 20px; border-radius: 8px; cursor: pointer;">Отправить</button>
            </div>
        </div>
    </div>
}

@if (selectedRequest is not null)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.75); display: flex; justify-content: center; align-items: center; z-index: 999;">
        <div style="background: linear-gradient(135deg, #0b1f3d, #07111f); border: 1px solid #2e5ea7; border-radius: 14px; padding: 30px; width: 100%; max-width: 650px; color: white;">
            <h2 style="margin-top: 0;">Детали заявки #@selectedRequest.RequestId</h2>

            <div style="display: grid; gap: 12px;">
                <div><strong style="color: #8aa8cc;">Тип авто:</strong> <span style="color: white;">@selectedRequest.VehicleType</span></div>
                <div><strong style="color: #8aa8cc;">Дата поездки:</strong> <span style="color: white;">@selectedRequest.TripDate.ToString("dd.MM.yyyy")</span></div>
                <div><strong style="color: #8aa8cc;">Начало:</strong> <span style="color: white;">@(selectedRequest.StartTime.HasValue ? selectedRequest.StartTime.Value.ToString(@"hh\:mm") : "-")</span></div>
                <div><strong style="color: #8aa8cc;">Окончание:</strong> <span style="color: white;">@(selectedRequest.EndTime.HasValue ? selectedRequest.EndTime.Value.ToString(@"hh\:mm") : "-")</span></div>
                <div><strong style="color: #8aa8cc;">Описание:</strong> <span style="color: white;">@selectedRequest.Description</span></div>
                <div>
                    <strong style="color: #8aa8cc;">Статус:</strong>
                    <span style="padding: 4px 12px; border-radius: 20px; font-weight: 700; margin-left: 8px;
                                 background: @GetStatusBackground(selectedRequest.Status);
                                 color: @GetStatusColor(selectedRequest.Status);">
                        @(selectedRequest.Status == "Pending" ? "Ожидает" :
                          selectedRequest.Status == "Approved" ? "Одобрена" :
                          selectedRequest.Status == "Completed" ? "Завершена" : "Отклонена")
                    </span>
                </div>
                @if (!string.IsNullOrEmpty(selectedRequest.RejectionReason))
                {
                    <div><strong style="color: #8aa8cc;">Причина отказа:</strong> <span style="color: white;">@selectedRequest.RejectionReason</span></div>
                }
            </div>

            @if (selectedRequest.Status == "Approved")
            {
                <div style="margin-top: 20px; padding: 16px; background: rgba(47,110,219,0.1); border-left: 4px solid #2f6edb; border-radius: 8px;">
                    <div><strong style="color: #8aa8cc;">Автомобиль:</strong> <span style="color: white;">@selectedRequest.VehicleBrand @selectedRequest.VehicleModel</span></div>
                    <div><strong style="color: #8aa8cc;">Госномер:</strong> <span style="color: white;">@selectedRequest.LicensePlate</span></div>
                    <div><strong style="color: #8aa8cc;">Водитель:</strong> <span style="color: white;">@selectedRequest.DriverName</span></div>
                    <div><strong style="color: #8aa8cc;">Телефон:</strong> <span style="color: white;">@selectedRequest.DriverPhone</span></div>
                </div>
            }

            <button @onclick="CloseDetails" style="background: #2f6edb; border: none; color: white; padding: 10px 20px; border-radius: 8px; cursor: pointer; margin-top: 20px; width: 100%;">Закрыть</button>
        </div>
    </div>
}

<style>
    tr:hover {
        background: rgba(47,110,219,0.08);
    }
</style>