@page "/employee/dashboard"
@using Microsoft.AspNetCore.Authorization
@using Radzen.Blazor
@using CP.Server.DTO
@attribute [Authorize(Roles = "Employee")]

<PageTitle>Employee - Dashboard</PageTitle>

<div style="min-height: 100vh; background: linear-gradient(135deg, #0a1628 0%, #0d1f3e 100%); padding: 20px;">
    <div style="max-width: 1400px; margin: 0 auto;">

        <div style="margin-bottom: 30px;">
            <div style="color: #e0e8f0; font-size: 28px; font-weight: 700;">
                DASHBOARD СОТРУДНИКА
            </div>
            <div style="color: #8aa8cc; font-size: 14px; margin-top: 8px;">
                Управление командировками, заявками и поездками
            </div>
        </div>

        <div class="stats-grid-modern">

            <div class="dashboard-card">
                <div class="stat-value">@data.PendingRequests</div>
                <div class="stat-label">Ожидают рассмотрения</div>
            </div>

            <div class="dashboard-card">
                <div class="stat-value">@data.ApprovedRequests</div>
                <div class="stat-label">Одобрены</div>
            </div>

            <div class="dashboard-card">
                <div class="stat-value">@data.CompletedRequests</div>
                <div class="stat-label">Завершены</div>
            </div>

            <div class="dashboard-card">
                <div class="stat-value">@data.RejectedRequests</div>
                <div class="stat-label">Отклонены</div>
            </div>

        </div>

        <div class="dashboard-main-grid">

            <div style="display: flex; flex-direction: column; gap: 24px;">

                <div class="dashboard-panel">
                    <div class="section-header">
                        Ближайшая поездка
                    </div>

                    @if (data.UpcomingTrip != null)
                    {
                        <div class="trip-info-box">
                            <div class="trip-date">@data.UpcomingTrip.TripDate.ToString("dd.MM.yyyy")</div>
                            <div class="trip-details">
                                <div><strong>Автомобиль:</strong> @data.UpcomingTrip.VehicleName</div>
                                <div><strong>Водитель:</strong> @data.UpcomingTrip.DriverName</div>
                                <div><strong>Статус:</strong> <span class="status-badge">@data.UpcomingTrip.Status</span></div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state-box">
                            <div style="font-size: 48px; margin-bottom: 12px;">Пусто</div>
                            <div style="font-size: 18px; font-weight: 600;">Нет запланированных поездок</div>
                            <div style="font-size: 14px; margin-top: 8px;">Создайте новую заявку для организации поездки</div>
                        </div>
                    }
                </div>

                <div class="dashboard-panel">
                    <div class="section-header">
                        Быстрое действие
                    </div>

                    <button class="primary-action-btn"
                            @onclick='() => NavigationManager.NavigateTo("/employee/trip-requests")'>
                        + СОЗДАТЬ ЗАЯВКУ
                    </button>
                </div>

            </div>

            <div class="dashboard-panel">
                <div class="section-header">
                    История последних заявок
                </div>

                @if (data.RecentRequests.Any())
                {
                    <div class="requests-list">
                        @foreach (var request in data.RecentRequests)
                        {
                            <div class="request-item">
                                <div class="request-date">@request.TripDate.ToString("dd.MM.yyyy")</div>
                                <div class="request-vehicle">@request.VehicleType</div>
                                <div class="request-status status-@request.Status.ToLower()">@request.Status</div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state-box">
                        <div style="font-size: 48px; margin-bottom: 12px;">Пусто</div>
                        <div style="font-size: 18px; font-weight: 600;">Нет заявок</div>
                        <div style="font-size: 14px; margin-top: 8px;">Ваши заявки будут отображаться здесь</div>
                    </div>
                }

                <div style="margin-top: 20px; text-align: center;">
                    <button class="secondary-action-btn"
                            @onclick='() => NavigationManager.NavigateTo("/employee/trip-requests")'>
                        Все заявки →
                    </button>
                </div>
            </div>

        </div>

        <div class="info-banner">
            ℹ <strong>Информация:</strong> Используйте dashboard для быстрого доступа к заявкам, истории поездок и текущему статусу командировок.
        </div>

    </div>
</div>

<style>
    .stats-grid-modern {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 24px;
        margin-bottom: 32px;
    }

    .dashboard-card {
        background: linear-gradient(135deg, #0d1f3e 0%, #0a1628 100%);
        border: 1px solid #2a4a8e;
        border-radius: 12px;
        padding: 24px;
        text-align: center;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .dashboard-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.3);
        border-color: #3a7bd5;
    }

    .stat-icon-box {
        width: 70px;
        height: 70px;
        margin: 0 auto 16px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 32px;
        font-weight: bold;
    }

    .pending {
        background: rgba(255,193,7,0.15);
        color: #ffc107;
    }

    .approved {
        background: rgba(76,175,80,0.15);
        color: #4caf50;
    }

    .completed {
        background: rgba(58,123,213,0.15);
        color: #3a7bd5;
    }

    .rejected {
        background: rgba(220,53,69,0.15);
        color: #dc3545;
    }

    .stat-value {
        font-size: 42px;
        font-weight: 700;
        color: #e0e8f0;
    }

    .stat-label {
        color: #8aa8cc;
        font-size: 14px;
        margin-top: 8px;
    }

    .dashboard-main-grid {
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 24px;
        margin-bottom: 30px;
    }

    .dashboard-panel {
        background: linear-gradient(135deg, #0d1f3e 0%, #0a1628 100%);
        border: 1px solid #2a4a8e;
        border-radius: 12px;
        padding: 24px;
    }

    .section-header {
        color: #e0e8f0;
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 20px;
        padding-bottom: 14px;
        border-bottom: 1px solid #2a4a8e;
    }

    .empty-state-box {
        text-align: center;
        padding: 40px 20px;
        background: rgba(42,74,142,0.1);
        border: 1px dashed #2a4a8e;
        border-radius: 12px;
        color: #8aa8cc;
    }

    .primary-action-btn {
        width: 100%;
        background: linear-gradient(135deg, #1e5799 0%, #3a7bd5 100%);
        border: none;
        color: white;
        padding: 16px;
        border-radius: 10px;
        font-size: 16px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .primary-action-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(58,123,213,0.3);
    }

    .secondary-action-btn {
        background: transparent;
        border: 1px solid #2a4a8e;
        color: #8aa8cc;
        padding: 12px 20px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .secondary-action-btn:hover {
        border-color: #3a7bd5;
        color: #e0e8f0;
        transform: translateY(-2px);
    }

    .info-banner {
        margin-top: 30px;
        padding: 16px;
        background: rgba(58,123,213,0.1);
        border-left: 4px solid #3a7bd5;
        border-radius: 8px;
        color: #8aa8cc;
        font-size: 13px;
    }

    .trip-info-box {
        background: rgba(42,74,142,0.2);
        border-radius: 12px;
        padding: 20px;
    }

    .trip-date {
        font-size: 24px;
        font-weight: 700;
        color: #3a7bd5;
        margin-bottom: 16px;
    }

    .trip-details {
        color: #8aa8cc;
        font-size: 14px;
    }

    .trip-details div {
        margin-bottom: 8px;
    }

    .trip-details strong {
        color: #e0e8f0;
    }

    .status-badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        background: rgba(76,175,80,0.2);
        color: #4caf50;
    }

    .requests-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .request-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px;
        background: rgba(42,74,142,0.1);
        border-radius: 8px;
        flex-wrap: wrap;
        gap: 10px;
    }

    .request-date {
        font-weight: 600;
        color: #3a7bd5;
        min-width: 100px;
    }

    .request-vehicle {
        flex: 1;
        color: #e0e8f0;
    }

    .request-status {
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .status-pending {
        background: rgba(255,193,7,0.2);
        color: #ffc107;
    }

    .status-approved {
        background: rgba(76,175,80,0.2);
        color: #4caf50;
    }

    .status-completed {
        background: rgba(58,123,213,0.2);
        color: #3a7bd5;
    }

    .status-rejected {
        background: rgba(220,53,69,0.2);
        color: #dc3545;
    }

    @@media (max-width: 992px) {
        .dashboard-main-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 768px) {
        .stats-grid-modern {
            grid-template-columns: 1fr;
        }

        .dashboard-card {
            padding: 20px;
        }

        .section-header {
            font-size: 18px;
        }
        
        .request-item {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>