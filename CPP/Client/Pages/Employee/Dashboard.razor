@page "/employee/dashboard"
@using Microsoft.AspNetCore.Authorization
@using Radzen.Blazor
@attribute [Authorize(Roles = "Employee")]

<PageTitle>Employee - Dashboard</PageTitle>

<style>
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }
    
    .stat-card {
        background: linear-gradient(135deg, #1a2a3a 0%, #16212e 100%);
        border: 1px solid #2a4a6e;
        border-radius: 12px;
        padding: 20px;
        text-align: center;
        transition: all 0.3s ease;
    }
    
    .stat-card:hover {
        transform: translateY(-5px);
        border-color: #3a8bc5;
    }
    
    .stat-value {
        font-size: 36px;
        font-weight: bold;
        color: #2b7abf;
    }
    
    .stat-label {
        color: #8aa0b5;
        margin-top: 10px;
        font-size: 14px;
    }
    
    .stat-icon {
        font-size: 32px;
        margin-bottom: 10px;
    }
    
    .info-card {
        background: linear-gradient(135deg, #1a2a3a 0%, #16212e 100%);
        border: 1px solid #2a4a6e;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 20px;
    }
    
    .section-title {
        color: #e0e8f0;
        font-size: 18px;
        margin-bottom: 15px;
        border-bottom: 1px solid #2a4a6e;
        padding-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    
    .btn-create {
        background: linear-gradient(135deg, #1e5799 0%, #2b7abf 100%);
        border: none;
        color: white;
        padding: 12px 24px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: bold;
        font-size: 16px;
        transition: all 0.3s ease;
        width: 100%;
    }
    
    .btn-create:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(30,87,153,0.4);
    }
    
    .btn-link {
        background: transparent;
        border: 1px solid #2a4a6e;
        color: #8aa0b5;
        padding: 8px 16px;
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    
    .btn-link:hover {
        border-color: #3a8bc5;
        color: #e0e8f0;
    }
    
    .upcoming-trip {
        background: linear-gradient(135deg, #0a121a 0%, #0d1620 100%);
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 15px;
    }
    
    .request-table {
        width: 100%;
        color: #8aa0b5;
    }
    
    .request-table th {
        text-align: left;
        padding: 10px;
        border-bottom: 1px solid #2a4a6e;
        color: #e0e8f0;
    }
    
    .request-table td {
        padding: 10px;
        border-bottom: 1px solid #2a4a6e;
    }
    
    .status-badge {
        padding: 4px 8px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: bold;
    }
    
    .status-pending { background: rgba(255,193,7,0.2); color: #ffc107; }
    .status-approved { background: rgba(40,167,69,0.2); color: #28a745; }
    .status-completed { background: rgba(23,162,184,0.2); color: #17a2b8; }
    .status-rejected { background: rgba(220,53,69,0.2); color: #dc3545; }
    
    .two-columns {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 30px;
    }
    
    @@media (max-width: 768px) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }
        .two-columns {
            grid-template-columns: 1fr;
        }
    }
</style>

<div style="padding: 20px; min-height: 100vh;">
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon"></div>
            <div class="stat-value">0</div>
            <div class="stat-label">Ожидают рассмотрения</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"></div>
            <div class="stat-value">0</div>
            <div class="stat-label">Одобрены</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"></div>
            <div class="stat-value">0</div>
            <div class="stat-label">Завершены</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"></div>
            <div class="stat-value">0</div>
            <div class="stat-label">Отклонены</div>
        </div>
    </div>
    
    <div class="two-columns">
        <div>
            <div class="info-card">
                <div class="section-title">Ближайшая поездка</div>
                <div class="upcoming-trip" style="text-align: center; color: #8aa0b5;">
                    Нет запланированных поездок
                </div>
            </div>
            
            <div class="info-card">
                <div class="section-title">Быстрое действие</div>
                <button class="btn-create" @onclick="GoToCreateRequest">+ СОЗДАТЬ ЗАЯВКУ</button>
            </div>
        </div>
        
        <div class="info-card">
            <div class="section-title">История последних заявок</div>
            <div style="text-align: center; padding: 40px; color: #8aa0b5;">
                Нет заявок
            </div>
            <div style="margin-top: 15px; text-align: center;">
                <button class="btn-link" @onclick="GoToAllRequests">Все заявки →</button>
            </div>
        </div>
    </div>
</div>

@code {
    [Inject]
    protected NavigationManager Navigation { get; set; }
    
    private void GoToCreateRequest()
    {
        Navigation.NavigateTo("/employee/trip-requests/create");
    }
    
    private void GoToAllRequests()
    {
        Navigation.NavigateTo("/employee/trip-requests");
    }
}