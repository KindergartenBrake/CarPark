@page "/"
@using Microsoft.AspNetCore.Authorization
@using Radzen.Blazor
@attribute [Authorize]

<PageTitle>CarPark - Главная</PageTitle>

<style>
    /* Брутальный синий фон */
    .brutal-page {
        min-height: 100vh;
        background: linear-gradient(135deg, #0a1928 0%, #0d2b3e 50%, #0a1928 100%);
        padding: 0;
    }
    
    /* Основная сетка */
    .main-grid {
        display: grid;
        grid-template-columns: 300px 1fr;
        gap: 20px;
        max-width: 1400px;
        margin: 0 auto;
        padding: 20px;
        min-height: calc(100vh - 40px);
    }
    
    /* Левая панель */
    .sidebar-panel {
        background: linear-gradient(135deg, #1a2a3a 0%, #16212e 100%);
        border-radius: 16px;
        border: 1px solid #2a4a6e;
        overflow: hidden;
        height: fit-content;
        position: sticky;
        top: 20px;
    }
    
    .sidebar-header {
        background: linear-gradient(135deg, #0a121a 0%, #0d1620 100%);
        color: #e0e8f0;
        font-size: 18px;
        font-weight: bold;
        padding: 20px;
        text-align: center;
        letter-spacing: 2px;
        border-bottom: 1px solid #2a4a6e;
        text-transform: uppercase;
    }
    
    .info-block {
        background: linear-gradient(135deg, #0a121a 0%, #0d1620 100%);
        margin: 15px;
        padding: 20px;
        border-radius: 12px;
        border: 1px solid #2a4a6e;
        text-align: center;
        transition: all 0.3s ease;
    }
    
    .info-block:hover {
        border-color: #3a8bc5;
        transform: translateY(-2px);
    }
    
    .info-title {
        color: #8aa0b5;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 10px;
    }
    
    .info-value {
        color: #e0e8f0;
        font-size: 16px;
        font-weight: 500;
    }
    
    /* Выпадающее меню */
    .dropdown-container {
        padding: 15px;
        border-bottom: 1px solid #2a4a6e;
    }
    
    .dropdown-label {
        color: #8aa0b5;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 10px;
        display: block;
    }
    
    .brutal-dropdown {
        width: 100%;
    }
    
    .brutal-dropdown .rz-dropdown {
        background: #0f1a24 !important;
        border: 1px solid #2a4a6e !important;
        border-radius: 8px !important;
    }
    
    .brutal-dropdown .rz-dropdown-trigger {
        color: #8aa0b5 !important;
    }
    
    .brutal-dropdown .rz-dropdown-item {
        color: #e0e8f0 !important;
        background: #1a2a3a !important;
    }
    
    .brutal-dropdown .rz-dropdown-item:hover {
        background: #2a4a6e !important;
    }
    
    /* Кнопки меню */
    .sidebar-buttons {
        padding: 15px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }
    
    .menu-btn {
        background: linear-gradient(135deg, #0a121a 0%, #0d1620 100%);
        border: 1px solid #2a4a6e;
        color: #8aa0b5;
        padding: 12px 20px;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
        font-size: 14px;
        font-weight: 500;
        text-align: left;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    
    .menu-btn:hover {
        background: linear-gradient(135deg, #1e5799 0%, #2b7abf 100%);
        border-color: #3a8bc5;
        color: white;
        transform: translateX(5px);
    }
    
    /* Правая панель */
    .content-panel {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }
    
    /* Блок новостей */
    .news-wrapper {
        background: linear-gradient(135deg, #1a2a3a 0%, #16212e 100%);
        border-radius: 16px;
        border: 1px solid #2a4a6e;
        overflow: hidden;
    }
    
    .news-header {
        background: linear-gradient(135deg, #0a121a 0%, #0d1620 100%);
        color: #e0e8f0;
        font-size: 16px;
        font-weight: bold;
        padding: 15px 20px;
        border-bottom: 1px solid #2a4a6e;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    
    .news-viewer {
        padding: 30px;
        min-height: 200px;
        color: #8aa0b5;
        text-align: center;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 15px;
    }
    
    /* Большой блок просмотра */
    .big-view-wrapper {
        background: linear-gradient(135deg, #1a2a3a 0%, #16212e 100%);
        border-radius: 16px;
        border: 1px solid #2a4a6e;
        overflow: hidden;
        flex: 1;
        display: flex;
        flex-direction: column;
    }
    
    .big-viewer {
        padding: 40px;
        min-height: 400px;
        color: #8aa0b5;
        text-align: center;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 20px;
        flex: 1;
    }
    
    .fullscreen-btn {
        background: linear-gradient(135deg, #1e5799 0%, #2b7abf 100%);
        border: 1px solid #3a8bc5;
        color: white;
        padding: 12px;
        margin: 15px;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    
    .fullscreen-btn:hover {
        background: linear-gradient(135deg, #2b6aae 0%, #3a8bc5 100%);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(30,87,153,0.4);
    }
    
    /* Заглушка для контента */
    .placeholder-content {
        background: #0f1a24;
        padding: 20px;
        border-radius: 8px;
        width: 100%;
        max-width: 400px;
        text-align: center;
    }
    
    /* Адаптивность */
    @@media (max-width: 768px) {
        .main-grid {
            grid-template-columns: 1fr;
            gap: 15px;
        }
        
        .sidebar-panel {
            position: static;
        }
        
        .big-viewer {
            min-height: 300px;
        }
    }
</style>

<div class="brutal-page">
    <div class="main-grid">
        
        <!-- Левая панель -->
        <div class="sidebar-panel">
            <div class="sidebar-header">
                 МЕНЮ
            </div>
            
            <div class="info-block">
                <div class="info-title"> ЛИЧНАЯ ИНФОРМАЦИЯ</div>
                <div class="info-value">Имя пользователя</div>
            </div>
            
            <!-- Выпадающий список -->
            <div class="dropdown-container">
                <label class="dropdown-label"> БЫСТРЫЙ ПЕРЕХОД</label>
                
            </div>
            
            <div class="sidebar-buttons">
                <button class="menu-btn" onclick="location.href='/Zayavki'"> заявки</button>
                <button class="menu-btn" onclick="location.href='/Cars'"> машина</button>
                <button class="menu-btn" onclick="location.href='/Voditeli'"> Водители</button>
                <button class="menu-btn" onclick="location.href='/Statistika'"> Статка</button>
            </div>
        </div>
        
        <!-- Правая панель -->
        <div class="content-panel">
            <!-- Новости -->
            <div class="news-wrapper">
                <div class="news-header">
                     ПОСЛЕДНИЕ НОВОСТИ
                </div>
                <div class="news-viewer">
                    <div class="placeholder-content">
                        Окно просмотра новостей
                    </div>
                </div>
            </div>
            
            <!-- Большой блок -->
            <div class="big-view-wrapper">
                <div class="big-viewer">
                    <div style="font-size: 48px;"></div>
                    <div>Окно просмотра информации, по кнопкам слева</div>
                </div>
                <button class="fullscreen-btn"> ВО ВЕСЬ ЭКРАН</button>
            </div>
        </div>
        
    </div>
</div>