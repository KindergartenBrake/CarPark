@page "/add-application-user"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

<PageTitle>Добавление пользователя</PageTitle>

<div style="min-height: 100vh;
            background: linear-gradient(135deg, #071120 0%, #0b1f3d 100%);
            padding: 24px;">
    
    <div style="max-width: 1200px; margin: 0 auto;">
        
        <!-- HEADER -->
        <div style="margin-bottom: 32px;">
            <div style="font-size: 34px;
                        font-weight: 900;
                        color: #edf4ff;
                        letter-spacing: 1px;">
                ДОБАВЛЕНИЕ ПОЛЬЗОВАТЕЛЯ
            </div>
            <div style="margin-top: 8px;
                        color: #89a7cf;
                        font-size: 14px;">
                Создание нового пользователя системы с назначением роли
            </div>
        </div>
        
        <!-- FORM CARD -->
        <div style="background: linear-gradient(145deg, #0d1c34 0%, #0a1628 100%);
                    border: 1px solid #1f4781;
                    border-radius: 20px;
                    padding: 32px;
                    position: relative;
                    overflow: hidden;">
            
            <div style="position: absolute;
                        top: 0;
                        left: 0;
                        width: 100%;
                        height: 4px;
                        background: linear-gradient(90deg, #3b82f6, #2563eb);">
            </div>
            
            <RadzenTemplateForm TItem="CP.Server.Models.ApplicationUser" 
                               Data="@user" 
                               Visible="@(user != null)" 
                               Submit="@FormSubmit">
                
                <!-- ERROR ALERT -->
                @if (errorVisible)
                {
                    <div style="background: rgba(220, 38, 38, 0.15);
                                border: 1px solid #dc2626;
                                border-radius: 12px;
                                padding: 14px 18px;
                                margin-bottom: 24px;
                                color: #fca5a5;">
                        @error
                    </div>
                }
                
                <div style="display: grid;
                            grid-template-columns: 1fr;
                            gap: 24px;">
                    
                    <!-- Email Field -->
                    <div>
                        <label style="display: block;
                                    color: #8aa8cc;
                                    font-size: 13px;
                                    font-weight: 700;
                                    letter-spacing: 0.5px;
                                    margin-bottom: 8px;">
                            EMAIL
                        </label>
                        <RadzenTextBox @bind-Value="@(user.Email)" 
                                      Name="Email"
                                      style="width: 100%;
                                             background: #08111f;
                                             border: 1px solid #1f4781;
                                             border-radius: 10px;
                                             padding: 12px 16px;
                                             color: #edf4ff;
                                             font-size: 14px;
                                             transition: all 0.2s;" />
                        <div style="margin-top: 6px;
                                    color: #fca5a5;
                                    font-size: 12px;">
                            <RadzenRequiredValidator Component="Email" Text="Email обязателен" />
                        </div>
                    </div>
                    
                    <!-- Roles Field -->
                    <div>
                        <label style="display: block;
                                    color: #8aa8cc;
                                    font-size: 13px;
                                    font-weight: 700;
                                    letter-spacing: 0.5px;
                                    margin-bottom: 8px;">
                            РОЛИ
                        </label>
                        <RadzenDropDown Data="@roles" 
                                       Multiple="true" 
                                       style="width: 100%;
                                              background: #08111f;
                                              border: 1px solid #1f4781;
                                              border-radius: 10px;
                                              padding: 8px 12px;
                                              color: #edf4ff;"
                                       TextProperty="Name" 
                                       @bind-Value="@(userRoles)" 
                                       ValueProperty="Id" 
                                       Name="Roles" />
                    </div>
                    
                    <!-- Password Field -->
                    <div>
                        <label style="display: block;
                                    color: #8aa8cc;
                                    font-size: 13px;
                                    font-weight: 700;
                                    letter-spacing: 0.5px;
                                    margin-bottom: 8px;">
                            ПАРОЛЬ
                        </label>
                        <RadzenPassword @bind-Value="@(user.Password)" 
                                       Name="Password"
                                       style="display: block;
                                              width: 100%;
                                              background: #08111f;
                                              border: 1px solid #1f4781;
                                              border-radius: 10px;
                                              padding: 12px 16px;
                                              color: #edf4ff;
                                              font-size: 14px;" />
                        <div style="margin-top: 6px;
                                    color: #fca5a5;
                                    font-size: 12px;">
                            <RadzenRequiredValidator Component="Password" Text="Пароль обязателен" />
                        </div>
                    </div>
                    
                    <!-- Confirm Password Field -->
                    <div>
                        <label style="display: block;
                                    color: #8aa8cc;
                                    font-size: 13px;
                                    font-weight: 700;
                                    letter-spacing: 0.5px;
                                    margin-bottom: 8px;">
                            ПОДТВЕРЖДЕНИЕ ПАРОЛЯ
                        </label>
                        <RadzenPassword style="display: block;
                                              width: 100%;
                                              background: #08111f;
                                              border: 1px solid #1f4781;
                                              border-radius: 10px;
                                              padding: 12px 16px;
                                              color: #edf4ff;
                                              font-size: 14px;" 
                                       @bind-Value="@(user.ConfirmPassword)" 
                                       Name="ConfirmPassword" />
                        <div style="margin-top: 6px;
                                    color: #fca5a5;
                                    font-size: 12px;">
                            <RadzenRequiredValidator Component="ConfirmPassword" Text="Подтверждение пароля обязательно" />
                            <RadzenCompareValidator Text="Пароли должны совпадать" 
                                                   Component="ConfirmPassword" 
                                                   Value="@user.Password" />
                        </div>
                    </div>
                    
                </div>
                
                <!-- BUTTONS -->
                <div style="display: flex;
                            justify-content: flex-end;
                            gap: 14px;
                            margin-top: 32px;
                            padding-top: 24px;
                            border-top: 1px solid #1f4781;">
                    
                    <button type="button"
                            style="background: #16263e;
                                   border: none;
                                   color: #8eb5ef;
                                   padding: 12px 24px;
                                   border-radius: 10px;
                                   cursor: pointer;
                                   font-weight: 700;
                                   font-size: 14px;
                                   transition: all 0.2s;"
                            onmouseover="this.style.background='#1e3050'; this.style.transform='translateY(-2px)'"
                            onmouseout="this.style.background='#16263e'; this.style.transform='translateY(0)'"
                            @onclick="CancelClick">
                        ОТМЕНА
                    </button>
                    
                    <button type="submit"
                            style="background: linear-gradient(135deg, #2563eb, #1d4ed8);
                                   border: none;
                                   color: white;
                                   padding: 12px 32px;
                                   border-radius: 10px;
                                   cursor: pointer;
                                   font-weight: 800;
                                   font-size: 14px;
                                   transition: all 0.2s;"
                            onmouseover="this.style.transform='translateY(-2px)'; this.style.opacity='0.93'"
                            onmouseout="this.style.transform='translateY(0)'; this.style.opacity='1'">
                        СОХРАНИТЬ
                    </button>
                    
                </div>
                
            </RadzenTemplateForm>
            
        </div>
        
    </div>
    
</div>

<!-- Простые стили для ховеров (так как Radzen не всегда корректно работает с inline-событиями) -->
<style>
    button {
        transition: all 0.2s ease !important;
    }
    
    .rz-dropdown {
        background: #08111f !important;
        border: 1px solid #1f4781 !important;
        border-radius: 10px !important;
    }
    
    .rz-dropdown .rz-dropdown-trigger {
        color: #8aa8cc !important;
    }
    
    .rz-multiselect .rz-multiselect-trigger {
        color: #8aa8cc !important;
    }
</style>