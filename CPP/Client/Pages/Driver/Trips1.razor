@page "/driver/trips1"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles="Driver")]

<PageTitle>Driver - Мои поездки</PageTitle>

<div style="min-height: 100vh; 
            background: linear-gradient(135deg, #071120 0%, #0b1f3d 100%); 
            padding: 24px;">
    
    <div style="width: 100%;">

        <div style="margin-bottom: 32px;">
            <div style="color: #edf4ff; font-size: 36px; font-weight: 900; letter-spacing: 1px;">
                МОИ ПОЕЗДКИ
            </div>
            <div style="color: #89a7cf; font-size: 14px; margin-top: 8px;">
                Управление назначенными, активными и завершёнными поездками
            </div>
        </div>

        <!-- TABS -->
        <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 28px; border-bottom: 2px solid #1f4781;">
            @foreach (var filter in tripFilters)
            {
                var currentFilter = filter;
                <button @onclick="() => SelectFilter(currentFilter)"
                        style="background: @(selectedFilter == currentFilter ? "#2563eb" : "transparent");
                               color: @(selectedFilter == currentFilter ? "white" : "#8aa8cc");
                               border: none;
                               padding: 14px 28px;
                               font-size: 14px;
                               font-weight: 700;
                               cursor: pointer;
                               border-radius: 12px 12px 0 0;
                               transition: all 0.3s ease;">
                    @GetFilterLabel(currentFilter)
                </button>
            }
        </div>

        <!-- TABLE -->
        <div style="background: rgba(12, 28, 51, 0.95);
                    border: 1px solid #1f4781;
                    border-radius: 20px;
                    overflow: hidden;
                    box-shadow: 0 10px 30px rgba(0,0,0,0.4);">

            <div style="overflow-x: auto;">
                <table style="width: 100%; border-collapse: collapse;">
                    <thead style="background: linear-gradient(90deg, #0d1c34, #0a1628);">
                        <tr>
                            <th style="padding: 18px; color: #8eb5ef; text-align: left; font-size: 13px;">ID</th>
                            <th style="padding: 18px; color: #8eb5ef; text-align: left; font-size: 13px;">Плановая дата/время</th>
                            <th style="padding: 18px; color: #8eb5ef; text-align: left; font-size: 13px;">Автомобиль</th>
                            <th style="padding: 18px; color: #8eb5ef; text-align: left; font-size: 13px;">Статус</th>
                            <th style="padding: 18px; color: #8eb5ef; text-align: left; font-size: 13px;">Пробег</th>
                            <th style="padding: 18px; color: #8eb5ef; text-align: center; font-size: 13px;">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (filteredTrips.Any())
                        {
                            @foreach (var trip in filteredTrips)
                            {
                                <tr style="border-bottom: 1px solid #1f4781;">
                                    <td style="padding: 16px; color: #e1edff; font-weight: 700;">
                                        #@trip.Id
                                    </td>
                                    <td style="padding: 16px; color: #e1edff;">
                                        @trip.ScheduledDate.ToString("dd.MM.yyyy HH:mm")
                                    </td>
                                    <td style="padding: 16px; color: #e1edff;">
                                        @trip.VehicleName
                                    </td>
                                    <td style="padding: 16px;">
                                        <span style="@GetStatusStyle(trip.Status)">
                                            @GetStatusText(trip.Status)
                                        </span>
                                    </td>
                                    <td style="padding: 16px; color: #e1edff;">
                                        @(trip.StartOdometer?.ToString() ?? "—")
                                        /
                                        @(trip.EndOdometer?.ToString() ?? "—")
                                    </td>
                                    <td style="padding: 16px; text-align: center;">
                                        <div style="display: flex; gap: 8px; justify-content: center; flex-wrap: wrap;">
                                            @if (trip.Status == "Scheduled")
                                            {
                                                <button @onclick="() => OpenStartModal(trip)"
                                                        style="@ActionButtonStyle("#2563eb")">
                                                    Начать поездку
                                                </button>
                                            }
                                            @if (trip.Status == "InProgress")
                                            {
                                                <button @onclick="() => OpenEndModal(trip)"
                                                        style="@ActionButtonStyle("#10b981")">
                                                    Завершить поездку
                                                </button>
                                            }
                                            <button @onclick="() => ShowDetails(trip)"
                                                    style="@ActionButtonStyle("#475569")">
                                                Детали
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" style="padding: 50px; text-align: center; color: #8aa8cc;">
                                    Нет поездок по выбранному фильтру
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>

<!-- START MODAL -->
@if (showStartModal && selectedTrip is not null)
{
    <div class="modal-overlay">
        <div class="modal-window">
            <h3 style="margin: 0 0 20px 0; font-size: 24px;">Начать поездку #@selectedTrip.Id</h3>

            <div class="form-group">
                <label>Показания одометра (начало)</label>
                <input type="number" @bind="startModel.StartOdometer" class="form-input" />
            </div>

            <div class="modal-actions">
                <button @onclick="StartTrip" class="primary-btn">Подтвердить</button>
                <button @onclick="CloseModals" class="secondary-btn">Отмена</button>
            </div>
        </div>
    </div>
}

<!-- END MODAL -->
@if (showEndModal && selectedTrip is not null)
{
    <div class="modal-overlay">
        <div class="modal-window">
            <h3 style="margin: 0 0 20px 0; font-size: 24px;">Завершить поездку #@selectedTrip.Id</h3>

            <div class="form-group">
                <label>Показания одометра (конец)</label>
                <input type="number" @bind="endModel.EndOdometer" class="form-input" />
            </div>

            <div class="modal-actions">
                <button @onclick="EndTrip" class="primary-btn">Завершить</button>
                <button @onclick="CloseModals" class="secondary-btn">Отмена</button>
            </div>
        </div>
    </div>
}

<style>
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.8);
        backdrop-filter: blur(4px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .modal-window {
        background: linear-gradient(145deg, #0d1c34 0%, #0a1628 100%);
        padding: 32px;
        border-radius: 20px;
        width: 450px;
        border: 1px solid #1f4781;
        color: #edf4ff;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        margin-bottom: 8px;
        color: #8aa8cc;
        font-weight: 600;
        font-size: 13px;
    }

    .form-input {
        width: 100%;
        padding: 12px;
        border-radius: 10px;
        border: 1px solid #1f4781;
        background: #08111f;
        color: #edf4ff;
        font-size: 14px;
    }

    .form-input:focus {
        outline: none;
        border-color: #3b82f6;
    }

    .modal-actions {
        display: flex;
        gap: 12px;
        margin-top: 24px;
        justify-content: flex-end;
    }

    .primary-btn {
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        border: none;
        color: white;
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 700;
        cursor: pointer;
        transition: 0.2s;
    }

    .secondary-btn {
        background: #1e293b;
        border: none;
        color: #8aa8cc;
        padding: 10px 20px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 700;
        transition: 0.2s;
    }

    .primary-btn:hover, .secondary-btn:hover {
        transform: translateY(-2px);
        opacity: 0.92;
    }
</style>