@page "/driver/profile1"
@using Microsoft.AspNetCore.Authorization
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using CP.Client
@using CP.Server.DTO
@inject HttpClient Http

<PageTitle>Профиль водителя</PageTitle>

<div style="min-height: 100vh; background: linear-gradient(135deg, #081120 0%, #0d1f3e 45%, #13376b 100%); padding: 24px;">
    <div style="max-width: 1400px; margin: 0 auto;">
        <!-- HEADER -->
        <div style="margin-bottom: 32px;">
            <div style="color: #f1f5ff; font-size: 34px; font-weight: 800; letter-spacing: 1px;">
                ПРОФИЛЬ ВОДИТЕЛЯ
            </div>
            <div style="color: #8aa8cc; font-size: 14px; margin-top: 8px;">
                Управление личными данными и безопасностью аккаунта
            </div>
        </div>

        <!-- MAIN GRID -->
        <div style="display: grid; grid-template-columns: 380px 1fr; gap: 24px;">
            <!-- LEFT PANEL -->
            <div style="background: linear-gradient(180deg, #102544 0%, #0a1628 100%); border: 1px solid #214d91; border-radius: 18px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.45);">
                <div style="padding: 40px 20px; border-bottom: 1px solid #1d3d72; background: linear-gradient(135deg, rgba(58,123,213,0.22), rgba(0,0,0,0));">
                    <div style="width: 120px; height: 120px; margin: 0 auto; border-radius: 50%; background: linear-gradient(135deg, #3a7bd5, #1f56a5); display: flex; align-items: center; justify-content: center; font-size: 42px; font-weight: 800; color: white; border: 4px solid rgba(255,255,255,0.08); box-shadow: 0 0 24px rgba(58,123,213,0.45);">
                        @GetInitials()
                    </div>
                    <div style="text-align: center; color: #f1f5ff; font-size: 24px; font-weight: 700; margin-top: 18px;">
                        @profile.FullName
                    </div>
                    <div style="text-align: center; color: #8aa8cc; font-size: 14px; margin-top: 8px;">
                        Водитель
                    </div>
                </div>

                <div style="padding: 24px;">
                    <div style="background: rgba(58,123,213,0.12); border: 1px solid #214d91; border-radius: 14px; padding: 18px;">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <div>
                                <div style="color: #8aa8cc; font-size: 12px; margin-bottom: 6px;">СТАТУС</div>
                                <div style="color: #4caf50; font-size: 15px; font-weight: 700;">@(profile.IsActive ? "Активен" : "Неактивен")</div>
                            </div>
                            <div style="width: 14px; height: 14px; border-radius: 50%; background: #4caf50; box-shadow: 0 0 14px #4caf50;"></div>
                        </div>
                    </div>

                    <div style="margin-top: 18px; display: flex; flex-direction: column; gap: 14px;">
                        <div style="background: rgba(0,0,0,0.25); border: 1px solid #1c396a; border-radius: 12px; padding: 14px;">
                            <div style="color: #8aa8cc; font-size: 11px; margin-bottom: 6px;">EMAIL</div>
                            <div style="color: #f1f5ff; font-size: 14px; font-weight: 600;">@profile.Email</div>
                        </div>
                        <div style="background: rgba(0,0,0,0.25); border: 1px solid #1c396a; border-radius: 12px; padding: 14px;">
                            <div style="color: #8aa8cc; font-size: 11px; margin-bottom: 6px;">ТЕЛЕФОН</div>
                            <div style="color: #f1f5ff; font-size: 14px; font-weight: 600;">@profile.Phone</div>
                        </div>
                        <div style="background: rgba(0,0,0,0.25); border: 1px solid #1c396a; border-radius: 12px; padding: 14px;">
                            <div style="color: #8aa8cc; font-size: 11px; margin-bottom: 6px;">ВОД. УДОСТОВЕРЕНИЕ</div>
                            <div style="color: #f1f5ff; font-size: 14px; font-weight: 600;">@profile.DriverLicenseNumber</div>
                        </div>
                        <div style="background: rgba(0,0,0,0.25); border: 1px solid #1c396a; border-radius: 12px; padding: 14px;">
                            <div style="color: #8aa8cc; font-size: 11px; margin-bottom: 6px;">СРОК ДЕЙСТВИЯ</div>
                            <div style="color: #f1f5ff; font-size: 14px; font-weight: 600;">@profile.LicenseExpiration.ToString("dd.MM.yyyy")</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- RIGHT CONTENT -->
            <div style="display: flex; flex-direction: column; gap: 24px;">
                <!-- PROFILE FORM -->
                <div style="background: linear-gradient(180deg, #102544 0%, #0a1628 100%); border: 1px solid #214d91; border-radius: 18px; padding: 28px; box-shadow: 0 10px 30px rgba(0,0,0,0.45);">
                    <div style="color: #f1f5ff; font-size: 24px; font-weight: 700; margin-bottom: 28px;">ЛИЧНЫЕ ДАННЫЕ</div>
                    <EditForm Model="@editModel" OnValidSubmit="SaveProfile">
                        <DataAnnotationsValidator />
                        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px;">
                            <div>
                                <label style="display: block; color: #8aa8cc; font-size: 12px; margin-bottom: 8px; letter-spacing: 0.6px;">ФИО</label>
                                <InputText @bind-Value="profile.FullName" disabled style="width: 100%; background: rgba(255,255,255,0.05); border: 1px solid #1f3f74; border-radius: 12px; color: #8aa8cc; padding: 14px; font-size: 14px;" />
                            </div>
                            <div>
                                <label style="display: block; color: #8aa8cc; font-size: 12px; margin-bottom: 8px; letter-spacing: 0.6px;">EMAIL</label>
                                <InputText @bind-Value="profile.Email" disabled style="width: 100%; background: rgba(255,255,255,0.05); border: 1px solid #1f3f74; border-radius: 12px; color: #8aa8cc; padding: 14px; font-size: 14px;" />
                            </div>
                            <div>
                                <label style="display: block; color: #8aa8cc; font-size: 12px; margin-bottom: 8px; letter-spacing: 0.6px;">ТЕЛЕФОН</label>
                                <InputText @bind-Value="editModel.Phone" style="width:100%;background:rgba(0,0,0,0.30);border:1px solid #214d91;border-radius:12px;color:#f1f5ff;padding:14px;font-size:14px;transition:all 0.25s ease;" />
                            </div>
                            <div>
                                <label style="display: block; color: #8aa8cc; font-size: 12px; margin-bottom: 8px; letter-spacing: 0.6px;">ВОДИТЕЛЬСКОЕ УДОСТОВЕРЕНИЕ</label>
                                <InputText @bind-Value="editModel.DriverLicenseNumber"
           disabled
           style="width: 100%; background: rgba(255,255,255,0.05); border: 1px solid #1f3f74; border-radius: 12px; color: #8aa8cc; padding: 14px; font-size: 14px;" />
                            </div>
                            <div>
                                <label style="display: block; color: #8aa8cc; font-size: 12px; margin-bottom: 8px; letter-spacing: 0.6px;">СРОК ДЕЙСТВИЯ ПРАВ</label>
                                <InputDate @bind-Value="editModel.LicenseExpiration" style="width: 100%; background: rgba(0,0,0,0.30); border: 1px solid #214d91; border-radius: 12px; color: #f1f5ff; padding: 14px; font-size: 14px; transition: all 0.25s ease;" />
                            </div>
                        </div>
                        <div style="margin-top: 30px; display: flex; justify-content: flex-end;">
                            <button type="submit" style="background: linear-gradient(135deg, #3a7bd5, #2358a8); color: white; border: none; padding: 14px 28px; border-radius: 12px; cursor: pointer; font-size: 14px; font-weight: 700; transition: all 0.25s ease; box-shadow: 0 0 18px rgba(58,123,213,0.45);">СОХРАНИТЬ ИЗМЕНЕНИЯ</button>
                        </div>
                    </EditForm>
                </div>

                <!-- PASSWORD CHANGE -->
                <div style="background: linear-gradient(180deg, #102544 0%, #0a1628 100%); border: 1px solid #214d91; border-radius: 18px; padding: 28px; box-shadow: 0 10px 30px rgba(0,0,0,0.45);">
                    <div style="color: #f1f5ff; font-size: 24px; font-weight: 700; margin-bottom: 28px;">СМЕНА ПАРОЛЯ</div>
                    <EditForm Model="@passwordModel" OnValidSubmit="ChangePassword">
                        <DataAnnotationsValidator />
                        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px;">
                            <div>
                                <label style="display: block; color: #8aa8cc; font-size: 12px; margin-bottom: 8px; letter-spacing: 0.6px;">ТЕКУЩИЙ ПАРОЛЬ</label>
                                <InputText type="password" @bind-Value="passwordModel.OldPassword" style="width: 100%; background: rgba(0,0,0,0.30); border: 1px solid #214d91; border-radius: 12px; color: #f1f5ff; padding: 14px; font-size: 14px; transition: all 0.25s ease;" />
                            </div>
                            <div>
                                <label style="display: block; color: #8aa8cc; font-size: 12px; margin-bottom: 8px; letter-spacing: 0.6px;">НОВЫЙ ПАРОЛЬ</label>
                                <InputText type="password" @bind-Value="passwordModel.NewPassword" style="width: 100%; background: rgba(0,0,0,0.30); border: 1px solid #214d91; border-radius: 12px; color: #f1f5ff; padding: 14px; font-size: 14px; transition: all 0.25s ease;" />
                            </div>
                            <div>
                                <label style="display: block; color: #8aa8cc; font-size: 12px; margin-bottom: 8px; letter-spacing: 0.6px;">ПОДТВЕРЖДЕНИЕ</label>
                                <InputText type="password" @bind-Value="passwordModel.ConfirmPassword" style="width: 100%; background: rgba(0,0,0,0.30); border: 1px solid #214d91; border-radius: 12px; color: #f1f5ff; padding: 14px; font-size: 14px; transition: all 0.25s ease;" />
                            </div>
                        </div>
                        <div style="margin-top: 30px; display: flex; justify-content: flex-end;">
                            <button type="submit" style="background: linear-gradient(135deg, #163f7d, #0f2e5e); color: white; border: none; padding: 14px 28px; border-radius: 12px; cursor: pointer; font-size: 14px; font-weight: 700; transition: all 0.25s ease; box-shadow: 0 0 18px rgba(22,63,125,0.45);">СМЕНИТЬ ПАРОЛЬ</button>
                        </div>
                    </EditForm>
                </div>

                <!-- SECURITY INFO -->
                <div style="background: rgba(58,123,213,0.12); border-left: 4px solid #3a7bd5; border-radius: 12px; padding: 18px 20px;">
                    <div style="color: #dce8ff; font-size: 14px; line-height: 1.6;">
                        <strong>Безопасность:</strong> После изменения пароля рекомендуется завершить все активные сессии и повторно авторизоваться.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    button:hover { transform: translateY(-2px); opacity: 0.95; }
    input:focus { outline: none; border-color: #3a7bd5 !important; box-shadow: 0 0 14px rgba(58,123,213,0.45); }
    @@media(max-width: 1000px) { div[style*="grid-template-columns: 380px 1fr"] { grid-template-columns: 1fr !important; } }
</style>

@code {
    [Inject] protected CarParkService CarParkService { get; set; } = default!;
    [Inject] protected NotificationService NotificationService { get; set; } = default!;

    private DriverProfileDto profile = new();  // ← это из CP.Server.DTO
    private DriverProfileEditModel editModel = new();
    private ChangePasswordModel passwordModel = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadProfile();
    }

    private async Task LoadProfile()
    {
        try
        {
            isLoading = true;
            profile = await CarParkService.GetDriverProfileAsync();
            editModel = new DriverProfileEditModel
            {
                FullName = profile.FullName,
                Email = profile.Email,
                Phone = profile.Phone,
                DriverLicenseNumber = profile.DriverLicenseNumber,
                LicenseExpiration = profile.LicenseExpiration,
                IsActive = profile.IsActive
            };
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки профиля: {ex.Message}");
            // Заглушка
            profile = new DriverProfileDto
            {
                FullName = "Александр Воронов",
                Email = "driver@fleet.local",
                Phone = "+7 (999) 123-45-67",
                DriverLicenseNumber = "77 AB 345672",
                LicenseExpiration = DateTime.Today.AddYears(3),
                IsActive = true
            };
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task SaveProfile()
    {
        try
        {
            profile.Phone = editModel.Phone;
            profile.DriverLicenseNumber = editModel.DriverLicenseNumber;
            profile.LicenseExpiration = editModel.LicenseExpiration;
            
            await CarParkService.UpdateDriverProfileAsync(profile);
            
            NotificationService.Notify(NotificationSeverity.Success, "Успех", "Профиль обновлён", duration: 3000);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", $"Не удалось сохранить: {ex.Message}", duration: 5000);
        }
    }

    private async Task ChangePassword()
    {
        if (passwordModel.NewPassword != passwordModel.ConfirmPassword)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Ошибка", "Пароли не совпадают", duration: 3000);
            return;
        }

        try
        {
            await CarParkService.ChangeDriverPasswordAsync(passwordModel.OldPassword, passwordModel.NewPassword);
            
            NotificationService.Notify(NotificationSeverity.Success, "Успех", "Пароль изменён", duration: 3000);
            passwordModel = new ChangePasswordModel();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", $"Не удалось сменить пароль: {ex.Message}", duration: 5000);
        }
    }

    private string GetInitials()
    {
        if (string.IsNullOrWhiteSpace(profile.FullName)) return "DR";
        var parts = profile.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][0].ToString().ToUpper();
        return $"{parts[0][0]}{parts[1][0]}".ToUpper();
    }

    // Только для формы редактирования (не DTO)
    public class DriverProfileEditModel
    {
        public string FullName { get; set; } = "";
        public string Email { get; set; } = "";
        public string Phone { get; set; } = "";
        public string DriverLicenseNumber { get; set; } = "";
        public DateTime LicenseExpiration { get; set; } = DateTime.Today.AddYears(3);
        public bool IsActive { get; set; } = true;
    }

    public class ChangePasswordModel
    {
        [Required] public string OldPassword { get; set; } = "";
        [Required] public string NewPassword { get; set; } = "";
        [Required] public string ConfirmPassword { get; set; } = "";
    }
}