@page "/create"
@using System.Collections.Generic

<div class="page-header">
    <h1>📝 Создание новой заявки</h1>
    <p>Заполните форму для отправки заявки на автомобиль</p>
</div>

<div class="create-grid">
    <div class="left">
        <div class="card preview-card">
            <h3>👁️ Предпросмотр заявки</h3>
            <div class="preview-content">
                <div class="preview-field">
                    <strong>Тип заявки:</strong> <span id="previewType">-</span>
                </div>
                <div class="preview-field">
                    <strong>Автомобиль:</strong> <span id="previewCar">-</span>
                </div>
                <div class="preview-field">
                    <strong>Водитель:</strong> <span id="previewDriver">-</span>
                </div>
                <div class="preview-field">
                    <strong>Описание:</strong> <span id="previewDesc">-</span>
                </div>
            </div>
        </div>

        <button class="btn-confirm" id="confirmBtn" onclick="confirmOrder()">
            ✅ Подтвердить
        </button>
    </div>

    <div class="right">
        <div class="card form-card">
            <h3>📋 Форма заявки</h3>
            <div class="form-group">
                <label>Тип заявки:</label>
                <select id="requestType" onchange="updatePreview()">
                    <option value="">Выберите тип</option>
                    <option value="Грузоперевозка">🚛 Грузоперевозка</option>
                    <option value="Пассажирская">🚐 Пассажирская</option>
                    <option value="Спецтехника">🏗️ Спецтехника</option>
                    <option value="Срочная">🚨 Срочная</option>
                </select>
            </div>

            <div class="form-group">
                <label>Выберите автомобиль:</label>
                <select id="carSelect" onchange="updatePreview()">
                    <option value="">Выберите авто</option>
                    <option value="Mercedes-Benz Actros">Mercedes-Benz Actros (Грузовой)</option>
                    <option value="Ford Transit">Ford Transit (Пассажирский)</option>
                    <option value="Toyota Camry">Toyota Camry (Легковой)</option>
                    <option value="MAN TGS">MAN TGS (Спецтехника)</option>
                </select>
            </div>

            <div class="form-group">
                <label>Выберите водителя:</label>
                <select id="driverSelect" onchange="updatePreview()">
                    <option value="">Выберите водителя</option>
                    <option value="Алексей Смирнов">Алексей Смирнов (Стаж: 8 лет)</option>
                    <option value="Дмитрий Кузнецов">Дмитрий Кузнецов (Стаж: 5 лет)</option>
                    <option value="Сергей Васильев">Сергей Васильев (Стаж: 3 года)</option>
                </select>
            </div>

            <div class="form-group">
                <label>Описание заявки:</label>
                <textarea id="description" rows="3" placeholder="Введите детали заявки..." oninput="updatePreview()"></textarea>
            </div>
        </div>

        <div class="card map-card">
            <h3>🗺️ Карта маршрута</h3>
            <div class="map-placeholder">
                <div class="map-point start">📍 Откуда: Москва, ул. Ленина</div>
                <div class="map-line"></div>
                <div class="map-point end">🏁 Куда: Санкт-Петербург, Невский пр.</div>
            </div>
            <div class="map-controls">
                <span>📏 Расстояние: ~705 км</span>
                <span>⏱️ Время: ~8.5 часов</span>
            </div>
        </div>

        <div class="actions">
            <button class="btn-submit" onclick="submitRequest()">
                📤 Отправить заявку
            </button>
            <button class="btn-clear" onclick="clearForm()">
                🗑️ Очистить форму
            </button>
        </div>
    </div>

    <div class="footer">
        <div class="employee-list">
            <h4>⭐ Ими гордится наша компания</h4>
            <div class="employees">
                <span>🏆 Иванов И. (100 рейсов)</span>
                <span>🏆 Петров П. (85 рейсов)</span>
                <span>🏆 Сидоров С. (72 рейса)</span>
            </div>
        </div>
    </div>

    <div class="support">
        <h4>🛠️ Техническая поддержка</h4>
        <p>📞 8-800-123-45-67</p>
        <p>✉️ support@autofleet.ru</p>
        <p>🕒 24/7</p>
    </div>
</div>

<script>
    function updatePreview() {
        const type = document.getElementById('requestType').selectedOptions[0]?.text || '-';
        const car = document.getElementById('carSelect').value || '-';
        const driver = document.getElementById('driverSelect').value || '-';
        const desc = document.getElementById('description').value || '-';

        document.getElementById('previewType').innerText = type;
        document.getElementById('previewCar').innerText = car;
        document.getElementById('previewDriver').innerText = driver;
        document.getElementById('previewDesc').innerText = desc.substring(0, 50);
    }

    function submitRequest() {
        const type = document.getElementById('requestType').value;
        if (!type) {
            alert('Пожалуйста, заполните все поля!');
            return;
        }
        alert('✅ Заявка успешно отправлена! Номер заявки: #' + Math.floor(Math.random() * 10000));
        clearForm();
    }

    function clearForm() {
        document.getElementById('requestType').value = '';
        document.getElementById('carSelect').value = '';
        document.getElementById('driverSelect').value = '';
        document.getElementById('description').value = '';
        updatePreview();
    }

    function confirmOrder() {
        const type = document.getElementById('requestType').value;
        if (!type) {
            alert('Сначала заполните форму!');
            return;
        }
        alert('✅ Заявка подтверждена! Ожидайте назначения водителя.');
    }
</script>